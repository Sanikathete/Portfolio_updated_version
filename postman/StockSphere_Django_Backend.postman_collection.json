      "name": "Users",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"{{username}}\",\n  \"email\": \"{{email}}\",\n  \"password\": \"{{password}}\",\n  \"phone\": \"{{phone}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/users/register/",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "users",
                "register",
                ""
              ]
            },
            "description": "Create a new Django user."
          }
        },
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "  const data = pm.response.json();",
                  "  if (data.access) pm.environment.set('accessToken', data.access);",
                  "  if (data.refresh) pm.environment.set('refreshToken', data.refresh);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"{{username}}\",\n  \"password\": \"{{password}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/users/login/",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "users",
                "login",
                ""
              ]
            },
            "description": "Obtain JWT access and refresh tokens."
          }
        },
        {
          "name": "Refresh Token",
          "request": {
            "method": "POST",
